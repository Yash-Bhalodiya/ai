# PART 1:
# Summary statistics (mean, median, min, max, std)
# grouped by a categorical variable using Titanic dataset
#
# PART 2:
# Statistical details of each species in Iris dataset
# ============================================================

# ------------------------------------------------------------
# STEP 1: Import Required Libraries
# ------------------------------------------------------------
import pandas as pd
import numpy as np
from sklearn.datasets import load_iris

# ============================================================
# PART 1: TITANIC DATASET
# ============================================================

print("=" * 60)
print("PART 1: SUMMARY STATISTICS USING TITANIC DATASET")
print("=" * 60)

# ------------------------------------------------------------
# STEP 2: Load Titanic Dataset
# Download titanic.csv from:
# https://www.kaggle.com/datasets/yasserh/titanic-dataset
# ------------------------------------------------------------
df = pd.read_csv("Titanic-Dataset.csv")

# Display first 5 rows
print("\nFirst 5 rows of Titanic Dataset:")
print(df.head())

# ------------------------------------------------------------
# STEP 3: Select Numeric Variable and Categorical Variable
# Numeric Variable      : Age
# Categorical Variable  : Sex
# ------------------------------------------------------------

# Remove missing values in Age
df = df.dropna(subset=['Age'])

# ------------------------------------------------------------
# STEP 4: Group by Categorical Variable and Compute Statistics
# ------------------------------------------------------------
grouped_stats = df.groupby('Sex')['Age'].agg([
    'mean', 'median', 'min', 'max', 'std'
])

print("\nSummary Statistics of Age Grouped by Sex:")
print(grouped_stats)

# ------------------------------------------------------------
# STEP 5: Create List of Age Values for Each Category
# ------------------------------------------------------------
age_lists = df.groupby('Sex')['Age'].apply(list)

print("\nList of Age Values for Each Category:")
for category, values in age_lists.items():
    print(f"\n{category}:")
    print(values[:20], "...")   # Display first 20 values only

# ============================================================
# PART 2: IRIS DATASET
# ============================================================

print("\n" + "=" * 60)
print("PART 2: STATISTICAL DETAILS OF IRIS DATASET")
print("=" * 60)

# ------------------------------------------------------------
# STEP 6: Load Iris Dataset from sklearn
# ------------------------------------------------------------
iris = load_iris()

# Create DataFrame
iris_df = pd.DataFrame(
    iris.data,
    columns=iris.feature_names
)

# Add species names
iris_df['species'] = pd.Categorical.from_codes(
    iris.target,
    iris.target_names
)

# Display first 5 rows
print("\nFirst 5 Rows of Iris Dataset:")
print(iris_df.head())

# ------------------------------------------------------------
# STEP 7: Group by Species and Display Statistics
# ------------------------------------------------------------
for species in iris_df['species'].unique():
    print("\n" + "=" * 50)
    print(f"STATISTICAL DETAILS FOR: {species.upper()}")
    print("=" * 50)

    subset = iris_df[iris_df['species'] == species]

    # Percentiles and summary statistics
    print(subset.describe())

# ------------------------------------------------------------
# STEP 8: Additional Percentiles (25%, 50%, 75%)
# ------------------------------------------------------------
print("\nCustom Percentiles for Each Species:")

for species in iris_df['species'].unique():
    print("\n" + "-" * 50)
    print(f"{species.upper()}")
    print("-" * 50)

    subset = iris_df[iris_df['species'] == species]

    percentiles = subset.quantile([0.25, 0.50, 0.75])
    print(percentiles)

# ------------------------------------------------------------
# STEP 9: Mean and Standard Deviation by Species
# (Updated to remove FutureWarning)
# ------------------------------------------------------------

print("\nMean of Each Feature by Species:")
print(iris_df.groupby('species', observed=False).mean())

print("\nStandard Deviation of Each Feature by Species:")
print(iris_df.groupby('species', observed=False).std())

# ------------------------------------------------------------
# STEP 10: Save Results (Optional)
# (Updated to remove FutureWarning)
# ------------------------------------------------------------

grouped_stats.to_csv("titanic_grouped_statistics.csv")

# Save mean values of each iris species
iris_df.groupby('species', observed=False).mean().to_csv(
    "iris_mean_by_species.csv"
)

print("\nResults saved successfully.")
print("1. titanic_grouped_statistics.csv")
print("2. iris_mean_by_species.csv")
print("\nPractical 3 completed successfully.")


Descriptive Statistics is a branch of statistics used to summarize, organize, 
and present data in a meaningful way. Instead of analyzing every individual 
observation, descriptive statistics condense large datasets into a few numerical 
measures that reveal the central value and the amount of variation in the data.

1. Measures of Central Tendency

Measures of central tendency indicate the “center” or typical value of a dataset.

Mean (Arithmetic Average)

The mean is the sum of all observations divided by the number of observations.


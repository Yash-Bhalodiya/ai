# ============================================================
# PRACTICAL 8: DATA VISUALIZATION I
# Titanic Dataset using Seaborn
#
# Objective:
# 1. Load the inbuilt Titanic dataset from Seaborn.
# 2. Explore patterns in the data using visualizations.
# 3. Plot a histogram to analyze the distribution of Fare.
# ============================================================

# ------------------------------------------------------------
# STEP 1: Import Required Libraries
# ------------------------------------------------------------
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Set plot style
sns.set_style("whitegrid")

# ------------------------------------------------------------
# STEP 2: Load Titanic Dataset
# ------------------------------------------------------------
# Titanic is an inbuilt dataset available in Seaborn
df = sns.load_dataset('titanic')

print("Titanic Dataset Loaded Successfully.\n")

# Display first 5 rows
print("First 5 Rows of Dataset:")
print(df.head())
print("\n")

# ------------------------------------------------------------
# STEP 3: Basic Information About Dataset
# ------------------------------------------------------------
print("Shape of Dataset:", df.shape)
print("\nColumn Names:")
print(df.columns.tolist())

print("\nMissing Values:")
print(df.isnull().sum())

print("\nStatistical Summary:")
print(df.describe())
print("\n")

# ------------------------------------------------------------
# STEP 4: Count Plot of Survival
# ------------------------------------------------------------
# Shows number of passengers who survived and did not survive
plt.figure(figsize=(6, 4))
sns.countplot(x='survived', data=df)
plt.title('Count of Survivors and Non-Survivors')
plt.xlabel('Survived (0 = No, 1 = Yes)')
plt.ylabel('Number of Passengers')
plt.show()

# ------------------------------------------------------------
# STEP 5: Count Plot of Survival by Gender
# ------------------------------------------------------------
# Helps identify whether gender affected survival
plt.figure(figsize=(6, 4))
sns.countplot(x='sex', hue='survived', data=df)
plt.title('Survival Count by Gender')
plt.xlabel('Gender')
plt.ylabel('Number of Passengers')
plt.legend(title='Survived')
plt.show()

# ------------------------------------------------------------
# STEP 6: Count Plot of Passenger Class
# ------------------------------------------------------------
# Shows distribution across ticket classes
plt.figure(figsize=(6, 4))
sns.countplot(x='class', data=df)
plt.title('Passenger Distribution by Class')
plt.xlabel('Class')
plt.ylabel('Number of Passengers')
plt.show()

# ------------------------------------------------------------
# STEP 7: Histogram of Age
# ------------------------------------------------------------
# Shows age distribution
plt.figure(figsize=(8, 5))
df['age'].hist(bins=30)
plt.title('Age Distribution of Passengers')
plt.xlabel('Age')
plt.ylabel('Frequency')
plt.show()

# ------------------------------------------------------------
# STEP 8: Histogram of Fare (Required in Practical)
# ------------------------------------------------------------
# Shows distribution of ticket prices
plt.figure(figsize=(8, 5))
plt.hist(df['fare'].dropna(), bins=30, edgecolor='black')
plt.title('Distribution of Fare')
plt.xlabel('Fare')
plt.ylabel('Number of Passengers')
plt.show()

# ------------------------------------------------------------
# STEP 9: Alternative Histogram Using Seaborn
# ------------------------------------------------------------
plt.figure(figsize=(8, 5))
sns.histplot(df['fare'].dropna(), bins=30, kde=True)
plt.title('Fare Distribution with KDE')
plt.xlabel('Fare')
plt.ylabel('Frequency')
plt.show()

# ------------------------------------------------------------
# STEP 10: Box Plot of Fare by Passenger Class
# ------------------------------------------------------------
# Helps identify outliers and compare fare across classes
plt.figure(figsize=(8, 5))
sns.boxplot(x='class', y='fare', data=df)
plt.title('Fare Distribution by Passenger Class')
plt.xlabel('Passenger Class')
plt.ylabel('Fare')
plt.show()

# ------------------------------------------------------------
# STEP 11: Pair Plot (Optional Pattern Exploration)
# ------------------------------------------------------------
# Visualizes relationships between numeric variables
sns.pairplot(
    df[['survived', 'age', 'fare', 'pclass']].dropna(),
    hue='survived'
)
plt.show()

# ------------------------------------------------------------
# STEP 12: Save Dataset (Optional)
# ------------------------------------------------------------
df.to_csv("titanic_seaborn.csv", index=False)

print("Titanic dataset saved as 'titanic_seaborn.csv'")
print("Practical 8 completed successfully.")
